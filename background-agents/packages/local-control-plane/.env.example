# Local Control Plane Configuration
# Copy to .env and fill in the values.

# Server port
PORT=8787

# Shared secret for HMAC auth (generate with: openssl rand -hex 32)
# Must match the sandbox manager's MODAL_API_SECRET.
MODAL_API_SECRET=dev-secret-change-me
INTERNAL_CALLBACK_SECRET=dev-secret-change-me

# Token encryption key (generate with: openssl rand -hex 32)
TOKEN_ENCRYPTION_KEY=

# GitHub App credentials (for repo listing and token generation)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_INSTALLATION_ID=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# URLs
WORKER_URL=http://localhost:8787
WEB_APP_URL=http://localhost:3000
SANDBOX_MANAGER_URL=http://localhost:8000

# Sandbox inactivity timeout (milliseconds)
SANDBOX_INACTIVITY_TIMEOUT_MS=600000

# Data directory for SQLite databases
# DATA_DIR=./data
