# Sandbox container image for Open-Inspect (local Kata Containers).
# Translates packages/modal-infra/src/images/base.py to a standard Dockerfile.
#
# Base: python:3.12-slim-bookworm (Debian bookworm slim with Python 3.12)

FROM python:3.12-slim-bookworm

# System packages (git, curl, build tools, Playwright deps)
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    curl \
    build-essential \
    ca-certificates \
    gnupg \
    openssh-client \
    jq \
    unzip \
    libnss3 \
    libnspr4 \
    libatk1.0-0 \
    libatk-bridge2.0-0 \
    libcups2 \
    libdrm2 \
    libxkbcommon0 \
    libxcomposite1 \
    libxdamage1 \
    libxfixes3 \
    libxrandr2 \
    libgbm1 \
    libasound2 \
    libpango-1.0-0 \
    libcairo2 \
    && rm -rf /var/lib/apt/lists/*

# Install GitHub CLI
RUN curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
      | dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg \
    && echo 'deb [arch=amd64 signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main' \
      > /etc/apt/sources.list.d/github-cli.list \
    && apt-get update && apt-get install -y gh && rm -rf /var/lib/apt/lists/*

# Install Node.js 22 LTS
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y nodejs \
    && node --version && npm --version

# Install pnpm and Bun
RUN npm install -g pnpm@latest && pnpm --version \
    && curl -fsSL https://bun.sh/install | bash \
    && echo 'export BUN_INSTALL="$HOME/.bun"' >> /etc/profile.d/bun.sh \
    && echo 'export PATH="$BUN_INSTALL/bin:$PATH"' >> /etc/profile.d/bun.sh

# Python tools
RUN pip install --no-cache-dir \
    uv \
    httpx \
    websockets \
    playwright \
    "pydantic>=2.0" \
    "PyJWT[crypto]"

# OpenCode CLI and plugin
RUN npm install -g opencode-ai@1.2.22 \
    && (opencode --version || echo 'OpenCode installed') \
    && npm install -g @opencode-ai/plugin@1.2.22 zod

# Playwright browsers (Chromium only)
RUN playwright install chromium \
    && playwright install-deps chromium

# Working directories
RUN mkdir -p /workspace /app/plugins /tmp/opencode \
    /cache/npm /cache/pnpm /cache/bun /cache/uv /cache/pip \
    && echo 'Image built for local Kata sandbox' > /app/image-version.txt

# Supply chain integrity: HTTPS-only package manager configs.
# pip.conf is system-wide (/etc/) so it applies regardless of which user runs pip.
# npmrc/pnpmrc are per-user (~/.npmrc) because npm/pnpm ignore system-level configs.
COPY packages/local-sandbox-manager/sandbox-config/pip.conf /etc/pip.conf

# Copy sandbox code (entrypoint, bridge, plugins, types)
COPY packages/modal-infra/src/sandbox/ /app/sandbox/

# ── Non-root sandbox user ────────────────────────────────────────────
RUN groupadd -g 1000 sandbox \
    && useradd -m -u 1000 -g 1000 -s /bin/bash sandbox

# Relocate Playwright browsers to shared location
ENV PLAYWRIGHT_BROWSERS_PATH=/opt/playwright-browsers
RUN mkdir -p /opt/playwright-browsers \
    && cp -a /root/.cache/ms-playwright/* /opt/playwright-browsers/ \
    && rm -rf /root/.cache/ms-playwright

# Relocate bun to sandbox user home
RUN cp -a /root/.bun /home/sandbox/.bun \
    && chown -R sandbox:sandbox /home/sandbox/.bun

# Relocate pnpm global store
RUN mkdir -p /home/sandbox/.local/share/pnpm \
    && chown -R sandbox:sandbox /home/sandbox/.local

# Fix ownership on all sandbox-writable directories
RUN chown -R sandbox:sandbox \
    /workspace /app \
    /cache/npm /cache/pnpm /cache/bun /cache/uv /cache/pip \
    /home/sandbox

# Copy package manager configs to sandbox user home
COPY packages/local-sandbox-manager/sandbox-config/npmrc /home/sandbox/.npmrc
COPY packages/local-sandbox-manager/sandbox-config/pnpmrc /home/sandbox/.pnpmrc
RUN chown sandbox:sandbox /home/sandbox/.npmrc /home/sandbox/.pnpmrc

# Environment variables
ENV HOME=/home/sandbox \
    NODE_ENV=development \
    PNPM_HOME=/home/sandbox/.local/share/pnpm \
    PATH=/home/sandbox/.bun/bin:/home/sandbox/.local/share/pnpm:/usr/local/bin:/usr/bin:/bin \
    PYTHONPATH=/app \
    SANDBOX_VERSION=local-kata \
    NODE_PATH=/usr/lib/node_modules \
    NPM_CONFIG_CACHE=/cache/npm \
    PNPM_STORE_DIR=/cache/pnpm \
    BUN_INSTALL_CACHE_DIR=/cache/bun \
    UV_CACHE_DIR=/cache/uv \
    PIP_CACHE_DIR=/cache/pip \
    UV_INDEX_URL=https://pypi.org/simple/

# Git config for sandbox user
RUN su sandbox -c 'git config --global user.name "Sandbox Agent"' \
    && su sandbox -c 'git config --global user.email "sandbox@druppie.local"'

# Make gh CLI writable by sandbox user so entrypoint.py can replace it
# with a wrapper script that redirects to the GitHub API proxy.
RUN rm -f /usr/local/bin/gh && touch /usr/local/bin/gh && chown sandbox:sandbox /usr/local/bin/gh

# Entrypoint wrapper for cache permission checks
COPY packages/local-sandbox-manager/sandbox-config/docker-entrypoint.sh /usr/local/bin/docker-entrypoint.sh
RUN chmod +x /usr/local/bin/docker-entrypoint.sh

USER sandbox
WORKDIR /workspace

ENTRYPOINT ["docker-entrypoint.sh"]
CMD ["python", "-m", "sandbox.entrypoint"]
