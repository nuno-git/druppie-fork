# Local Sandbox Manager Configuration
# Copy to .env and fill in the values.

# Shared secret for HMAC auth (must match control plane's MODAL_API_SECRET)
MODAL_API_SECRET=dev-secret-change-me

# GitHub App credentials (for generating installation tokens for sandbox git ops)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_INSTALLATION_ID=

# Anthropic API key (passed to sandboxes for LLM calls)
ANTHROPIC_API_KEY=

# ── Runtime selection ─────────────────────────────────────────────────────
# "docker" — Docker CLI. Cross-platform (Linux/Windows/macOS). Default.
# "kata"   — containerd + Kata Containers. Linux only, needs nested virt.
SANDBOX_RUNTIME=docker

# Sandbox image name
SANDBOX_IMAGE=open-inspect-sandbox:latest

# ── Docker-specific settings ──────────────────────────────────────────────
DOCKER_MEMORY_LIMIT=4g
DOCKER_CPU_LIMIT=2
DOCKER_PIDS_LIMIT=4096

# ── Kata-specific settings (only when SANDBOX_RUNTIME=kata) ──────────────
KATA_RUNTIME=io.containerd.kata.v2
CONTAINERD_NAMESPACE=default

# Directory for snapshot tars
SNAPSHOT_DIR=/data/snapshots
