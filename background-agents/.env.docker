# Copy this file to .env and fill in your API keys:
#   cp .env.docker .env

# ── LLM Provider Keys ────────────────────────────────────────────────────
# At least one is required for the agent to function.
ANTHROPIC_API_KEY=
ZHIPU_API_KEY=
GLM_API_KEY=

# ── Internal Auth (generate with: openssl rand -hex 32) ──────────────────
# MODAL_API_SECRET is used by control-plane and sandbox-manager.
# INTERNAL_CALLBACK_SECRET is used by the web app to authenticate to control-plane.
# They must match.
MODAL_API_SECRET=local-dev-secret
INTERNAL_CALLBACK_SECRET=local-dev-secret

# ── GitHub App (optional — needed for repo cloning) ──────────────────────
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_INSTALLATION_ID=

# ── GitHub OAuth (optional — needed for web login) ───────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
NEXTAUTH_SECRET=change-me-to-random-string
NEXTAUTH_URL=http://localhost:3000
