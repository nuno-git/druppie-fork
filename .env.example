# =============================================================================
# Druppie Governance Platform - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Variables with defaults (shown after :-) are optional.
# Variables without defaults are REQUIRED.
# =============================================================================

# =============================================================================
# HOST CONFIGURATION
# =============================================================================

# External hostname - change for production deployments
EXTERNAL_HOST=localhost

# =============================================================================
# DATABASE PASSWORDS
# =============================================================================

# Application database (PostgreSQL)
DRUPPIE_DB_PASSWORD=druppie_secret

# Keycloak database
KEYCLOAK_DB_PASSWORD=keycloak_secret

# Gitea database
GITEA_DB_PASSWORD=gitea_secret

# =============================================================================
# KEYCLOAK (Identity Provider)
# =============================================================================

# Keycloak admin credentials (for master realm)
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# OAuth2 client secrets (auto-generated during setup, or set manually)
# These are used for backend-to-keycloak and gitea-to-keycloak auth
KEYCLOAK_CLIENT_SECRET=
GITEA_CLIENT_SECRET=
GITEA_SECRET_KEY=

# =============================================================================
# GITEA (Git Server)
# =============================================================================

# Gitea admin user (created during initialization)
GITEA_ADMIN_USER=gitea_admin
GITEA_ADMIN_PASSWORD=GiteaAdmin123
GITEA_ADMIN_EMAIL=admin@druppie.local

# Gitea access token for MCP services (auto-generated during init)
# If empty, git push operations from MCP coding server won't work
GITEA_TOKEN=

# =============================================================================
# LLM CONFIGURATION (REQUIRED - set at least one provider)
# =============================================================================
# Both providers use LiteLLM internally for standardized tool calling.

# Provider: zai, deepinfra, deepseek, azure_foundry, ollama
LLM_PROVIDER=zai

# Override: force ALL agents to use this provider/model (ignores YAML per-agent config)
# LLM_FORCE_PROVIDER=
# LLM_FORCE_MODEL=

# --- Z.AI GLM Configuration ---
ZAI_API_KEY=
ZAI_MODEL=glm-4.7
ZAI_BASE_URL=https://api.z.ai/api/coding/paas/v4

# --- DeepInfra Configuration ---
# Uncomment and set to use DeepInfra instead:
# DEEPINFRA_API_KEY=
# DEEPINFRA_MODEL=Qwen/Qwen3-Next-80B-A3B-Instruct

# --- DeepSeek Configuration ---
# Uncomment and set to use DeepSeek instead:
# DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# --- Azure Foundry Configuration ---
# Uncomment and set to use Azure Foundry instead:
# FOUNDRY_API_KEY=
# FOUNDRY_MODEL=GPT-5-MINI
# FOUNDRY_API_URL=https://druppie.cognitiveservices.azure.com/openai/v1

# --- Ollama Configuration ---
# No API key required by default. Set OLLAMA_API_KEY only if your endpoint uses auth.
# Available models: gpt-oss:120b, gpt-oss:20b, qwen3-coder:30b, deepseek-r1:32b, gemma3:27b
# OLLAMA_MODEL=gpt-oss:20b
# OLLAMA_BASE_URL=https://ollama.waterschap.org/v1
# OLLAMA_API_KEY=
# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# Environment: "development" (default) or "production"/"staging"
# In production/staging, INTERNAL_API_KEY and SANDBOX_API_SECRET MUST be set
# to non-default values or the backend will refuse to start.
ENVIRONMENT=development

# Development mode - set to true to bypass Keycloak authentication
DEV_MODE=false

# Internal API key for MCP server communication (CHANGE for production!)
INTERNAL_API_KEY=druppie-internal-secret-key

# MCP Microservices toggle
USE_MCP_MICROSERVICES=true

# =============================================================================
# AZURE DATA LAKE CONFIGURATION
# =============================================================================
# PUBLIC lakes (e.g., Microsoft Azure Open Datasets) need NO configuration here.
# Agents access them freely by providing the account_url parameter in tool calls.
# Example public lake: https://azureopendatastorage.blob.core.windows.net
#
# PRIVATE lakes (with access keys) are pre-configured below.
# Format: account_name:account_key  (lake name defaults to account_name)
#     or: name:account_name:account_key  (explicit lake name)
# Multiple lakes: AZURE_DATA_LAKE_1, AZURE_DATA_LAKE_2, etc. (up to 9)
AZURE_DATA_LAKE_1=
# AZURE_DATA_LAKE_2=
# AZURE_DATA_LAKE_3=

# =============================================================================
# PORT CONFIGURATION (optional - defaults shown)
# =============================================================================
# Uncomment and change if you need different ports

# DRUPPIE_DB_PORT=5533
# KEYCLOAK_PORT=8180
# GITEA_PORT=3100
# GITEA_SSH_PORT=2223
# BACKEND_PORT=8100
# FRONTEND_PORT=5273
# MCP_CODING_PORT=9001
# MCP_DOCKER_PORT=9002
# MCP_HITL_PORT=9003
# MCP_FILESEARCH_PORT=9004
# MCP_WEB_PORT=9005
# MCP_ARCHIMATE_PORT=9006
# MCP_REGISTRY_PORT=9007
# MCP_AZURE_DATALAKE_PORT=9008
# ADMINER_PORT=8081

# =============================================================================
# SANDBOX / CODING AGENT (integrated - sandbox infrastructure starts automatically)
# =============================================================================
# Shared HMAC secret for sandbox authentication (must match between services)
SANDBOX_API_SECRET=sandbox-dev-secret
# LLM model used inside sandbox containers (REQUIRED — no universal default)
# Must match a model available on your configured LLM provider.
# Example: zai-coding-plan/glm-4.7, deepinfra/Qwen/Qwen3-Coder, ollama/gpt-oss:120b
SANDBOX_MODEL=
# Resource limits for sandbox containers (optional)
# SANDBOX_MEMORY_LIMIT=4g
# SANDBOX_CPU_LIMIT=2

# Sandbox runtime: "docker" (default, cross-platform) or "kata" (VM isolation, Linux + KVM only)
# See docs/KATA_CONTAINERS.md for Kata setup instructions
SANDBOX_RUNTIME=docker
# Kata-specific settings (only used when SANDBOX_RUNTIME=kata)
# KATA_RUNTIME=io.containerd.kata.v2
# CONTAINERD_NAMESPACE=default

# =============================================================================
# DRUPPIE CORE REPO (for update_core_builder agent - self-improvement via PRs)
# =============================================================================
# The repo where Druppie's own codebase lives (used when Architect signals
# DESIGN_APPROVED_CORE_UPDATE to modify the platform itself)
DRUPPIE_REPO_OWNER=nuno-git
DRUPPIE_REPO_NAME=druppie-fork

# =============================================================================
# GITHUB APP (for update_core_builder agent - authenticates against GitHub)
# =============================================================================
# Create a GitHub App at github.com/settings/apps/new with:
#   Permissions: Contents R/W, Pull Requests R/W, Metadata R
# Install on your fork repo, then fill in these values:
# GITHUB_APP_ID=
# GITHUB_APP_PRIVATE_KEY_PATH=/app/secrets/github-app-private-key.pem
# GITHUB_APP_INSTALLATION_ID=

# =============================================================================
# DOCKER SOCKET (optional - for rootless Docker)
# =============================================================================
# Set this to your rootless Docker socket if not using system Docker
# Find your path with: echo $XDG_RUNTIME_DIR/docker.sock
# DOCKER_SOCK=/run/user/1000/docker.sock
