# =============================================================================
# Druppie Governance Platform - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Variables with defaults (shown after :-) are optional.
# Variables without defaults are REQUIRED.
# =============================================================================

# =============================================================================
# HOST CONFIGURATION
# =============================================================================

# External hostname - change for production deployments
EXTERNAL_HOST=localhost

# =============================================================================
# DATABASE PASSWORDS
# =============================================================================

# Application database (PostgreSQL)
DRUPPIE_DB_PASSWORD=druppie_secret

# Keycloak database
KEYCLOAK_DB_PASSWORD=keycloak_secret

# Gitea database
GITEA_DB_PASSWORD=gitea_secret

# =============================================================================
# KEYCLOAK (Identity Provider)
# =============================================================================

# Keycloak admin credentials (for master realm)
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# OAuth2 client secrets (auto-generated during setup, or set manually)
# These are used for backend-to-keycloak and gitea-to-keycloak auth
KEYCLOAK_CLIENT_SECRET=
GITEA_CLIENT_SECRET=
GITEA_SECRET_KEY=

# =============================================================================
# GITEA (Git Server)
# =============================================================================

# Gitea admin user (created during initialization)
GITEA_ADMIN_USER=gitea_admin
GITEA_ADMIN_PASSWORD=GiteaAdmin123
GITEA_ADMIN_EMAIL=admin@druppie.local

# Gitea access token for MCP services (auto-generated during init)
# If empty, git push operations from MCP coding server won't work
GITEA_TOKEN=

# =============================================================================
# LLM CONFIGURATION (REQUIRED - set at least one provider)
# =============================================================================

# LLM Provider: litellm (recommended), zai, deepinfra, auto
# "auto" will try providers in order: litellm > deepinfra > zai
LLM_PROVIDER=litellm

# =============================================================================
# LITELLM CONFIGURATION (Recommended - unified interface for 100+ providers)
# =============================================================================
# LiteLLM provides a unified API across all LLM providers with standardized
# tool calling, automatic retries, and logging.

# API key for the underlying provider
LITELLM_API_KEY=

# Which provider to use internally: deepinfra, zai, openai, anthropic
LITELLM_PROVIDER=deepinfra

# Model name (provider-specific, see examples below)
# DeepInfra: Qwen/Qwen3-32B, meta-llama/Llama-3.3-70B-Instruct
# ZAI: GLM-4.7
# OpenAI: gpt-4, gpt-4-turbo, gpt-3.5-turbo
# Anthropic: claude-3-opus-20240229, claude-3-sonnet-20240229
LITELLM_MODEL=Qwen/Qwen3-32B

# Custom API base URL (optional - uses provider default if not set)
# LITELLM_API_BASE=

# Generation settings
LITELLM_MAX_TOKENS=16384
LITELLM_TEMPERATURE=0.7
LITELLM_TIMEOUT=300
LITELLM_MAX_RETRIES=3

# =============================================================================
# LEGACY PROVIDERS (use if not using LiteLLM)
# =============================================================================

# --- Z.AI GLM Configuration ---
ZAI_API_KEY=
ZAI_MODEL=GLM-4.7
ZAI_BASE_URL=https://api.z.ai/api/coding/paas/v4

# --- DeepInfra Configuration (OpenAI-compatible API) ---
DEEPINFRA_API_KEY=
DEEPINFRA_MODEL=Qwen/Qwen3-Next-80B-A3B-Instruct
DEEPINFRA_BASE_URL=https://api.deepinfra.com/v1/openai

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# Development mode - set to true to bypass Keycloak authentication
DEV_MODE=false

# Internal API key for MCP server communication
INTERNAL_API_KEY=druppie-internal-secret-key

# MCP Microservices toggle
USE_MCP_MICROSERVICES=true

# =============================================================================
# PORT CONFIGURATION (optional - defaults shown)
# =============================================================================
# Uncomment and change if you need different ports

# DRUPPIE_DB_PORT=5533
# KEYCLOAK_PORT=8180
# GITEA_PORT=3100
# GITEA_SSH_PORT=2223
# BACKEND_PORT=8100
# FRONTEND_PORT=5273
# MCP_CODING_PORT=9001
# MCP_DOCKER_PORT=9002
# MCP_FILESEARCH_PORT=9004
# MCP_WEB_PORT=9005
# ADMINER_PORT=8081
