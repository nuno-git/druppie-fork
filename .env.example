# =============================================================================
# Druppie Governance Platform - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Variables with defaults (shown after :-) are optional.
# Variables without defaults are REQUIRED.
# =============================================================================

# =============================================================================
# HOST CONFIGURATION
# =============================================================================

# External hostname - change for production deployments
EXTERNAL_HOST=localhost

# =============================================================================
# DATABASE PASSWORDS
# =============================================================================

# Application database (PostgreSQL)
DRUPPIE_DB_PASSWORD=druppie_secret

# Keycloak database
KEYCLOAK_DB_PASSWORD=keycloak_secret

# Gitea database
GITEA_DB_PASSWORD=gitea_secret

# =============================================================================
# KEYCLOAK (Identity Provider)
# =============================================================================

# Keycloak admin credentials (for master realm)
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# OAuth2 client secrets (auto-generated during setup, or set manually)
# These are used for backend-to-keycloak and gitea-to-keycloak auth
KEYCLOAK_CLIENT_SECRET=
GITEA_CLIENT_SECRET=
GITEA_SECRET_KEY=

# =============================================================================
# GITEA (Git Server)
# =============================================================================

# Gitea admin user (created during initialization)
GITEA_ADMIN_USER=gitea_admin
GITEA_ADMIN_PASSWORD=GiteaAdmin123
GITEA_ADMIN_EMAIL=admin@druppie.local

# Gitea access token for MCP services (auto-generated during init)
# If empty, git push operations from MCP coding server won't work
GITEA_TOKEN=

# =============================================================================
# LLM CONFIGURATION (REQUIRED - set at least one provider)
# =============================================================================
# Both providers use LiteLLM internally for standardized tool calling.

# Provider: zai, deepinfra, deepseek, azure_foundry, ollama
LLM_PROVIDER=zai

# Override: force ALL agents to use this provider/model (ignores YAML per-agent config)
# LLM_FORCE_PROVIDER=
# LLM_FORCE_MODEL=

# --- Z.AI GLM Configuration ---
ZAI_API_KEY=
ZAI_MODEL=glm-4.7
ZAI_BASE_URL=https://api.z.ai/api/coding/paas/v4

# --- DeepInfra Configuration ---
# Uncomment and set to use DeepInfra instead:
# DEEPINFRA_API_KEY=
# DEEPINFRA_MODEL=Qwen/Qwen3-Next-80B-A3B-Instruct

# --- DeepSeek Configuration ---
# Uncomment and set to use DeepSeek instead:
# DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# --- Azure Foundry Configuration ---
# Uncomment and set to use Azure Foundry instead:
# FOUNDRY_API_KEY=
# FOUNDRY_MODEL=GPT-5-MINI
# FOUNDRY_API_URL=https://druppie.cognitiveservices.azure.com/openai/v1

# --- Ollama Configuration ---
# No API key required by default. Set OLLAMA_API_KEY only if your endpoint uses auth.
# OLLAMA_MODEL=gpt-oss:20b
# OLLAMA_BASE_URL=https://ollama.waterschap.org/v1
# OLLAMA_API_KEY=
# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# Development mode - set to true to bypass Keycloak authentication
DEV_MODE=false

# Internal API key for MCP server communication
INTERNAL_API_KEY=druppie-internal-secret-key

# MCP Microservices toggle
USE_MCP_MICROSERVICES=true

# MCP Coding Server URL (internal Docker network URL)
MCP_CODING_URL=http://mcp-coding:9001

# =============================================================================
# PORT CONFIGURATION (optional - defaults shown)
# =============================================================================
# Uncomment and change if you need different ports

# DRUPPIE_DB_PORT=5533
# KEYCLOAK_PORT=8180
# GITEA_PORT=3100
# GITEA_SSH_PORT=2223
# BACKEND_PORT=8100
# FRONTEND_PORT=5273
# MCP_CODING_PORT=9001
# MCP_DOCKER_PORT=9002
# MCP_FILESEARCH_PORT=9004
# MCP_WEB_PORT=9005
# ADMINER_PORT=8081

# =============================================================================
# DOCKER SOCKET (optional - for rootless Docker)
# =============================================================================
# Set this to your rootless Docker socket if not using system Docker
# Find your path with: echo $XDG_RUNTIME_DIR/docker.sock
# DOCKER_SOCK=/run/user/1000/docker.sock
